# Supabase Configuration
# Copy this file to .env.local and fill in with your Supabase credentials
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

# Public URL for Supabase - used by the frontend
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public ANON key for Supabase - used by the frontend
# Get the "anon public" key from your Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key - used for admin operations (KEEP THIS SECRET!)
# Get the "service_role" key from your Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database URL for direct connections (same as project URL)
SUPABASE_DB_URL=https://your-project.supabase.co

# Meta WhatsApp Business API
# META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# META_PHONE_NUMBER_ID=your_phone_number_id
# META_BUSINESS_ACCOUNT_ID=your_business_account_id

# Meta Webhook (WhatsApp CTA buttons)
# Token secreto para validar que o webhook vem do Facebook
# Deve ser o mesmo valor configurado no Meta Business Manager
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Other environment variables
# DATABASE_URL=postgresql://...
# OPENAI_API_KEY=...
# RESEND_API_KEY=...
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
